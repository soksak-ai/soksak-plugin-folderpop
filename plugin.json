{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-folderpop",
  "name": {
    "ko": "\ud3f4\ub354\ud31d",
    "en": "Folderpop"
  },
  "version": "0.0.1",
  "description": {
    "ko": "\uc88c\uce21 \uc0ac\uc774\ub4dc\ubc14 \ud3f4\ub354 \ud0d0\uc0c9\uae30 \u2014 \uc5ec\ub7ec \ud3f4\ub354\ub97c \ub4f1\ub85d\ud558\uace0(\uac01 \uc774\ub984 \ubcc0\uacbd) \uc120\ud0dd\ud55c \ud3f4\ub354\uc758 \ud30c\uc77c/\ud3f4\ub354\ub97c \ubcf4\uc5ec\uc900\ub2e4. \ud30c\uc77c \uc5f4\uae30\ub294 \ucf54\uc5b4 editor.open \uc73c\ub85c \uc704\uc784.",
    "en": "Left sidebar folder explorer \u2014 register multiple folders (each renamable) and browse the selected folder's files/folders. Opening a file is delegated to the core editor.open command."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "fs:read",
    "data",
    "commands"
  ],
  "contributes": {
    "views": [
      {
        "id": "folders",
        "title": {
          "ko": "\ud3f4\ub354\ud31d",
          "en": "Folderpop"
        },
        "icon": "\ud83d\udcc2",
        "placements": [
          "sidebar-left"
        ],
        "defaultPlacement": "sidebar-left"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "\uc801\uc7ac/\ubc84\uc804 \ud655\uc778(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "list",
        "title": {
          "ko": "\ub4f1\ub85d \ud3f4\ub354 \ubaa9\ub85d",
          "en": "List folders"
        }
      },
      {
        "name": "add",
        "title": {
          "ko": "\ud3f4\ub354 \ub4f1\ub85d",
          "en": "Add folder"
        }
      },
      {
        "name": "remove",
        "title": {
          "ko": "\ud3f4\ub354 \uc81c\uac70",
          "en": "Remove folder"
        }
      },
      {
        "name": "rename",
        "title": {
          "ko": "\ud3f4\ub354 \uc774\ub984 \ubcc0\uacbd",
          "en": "Rename folder"
        }
      },
      {
        "name": "select",
        "title": {
          "ko": "\ud65c\uc131 \ud3f4\ub354 \uc120\ud0dd",
          "en": "Select active folder"
        }
      }
    ],
    "nodes": [
      {
        "id": "chip",
        "description": "Registered-folder chip; click selects it as the active folder. data-node=\"chip/<pathKey>\"."
      },
      {
        "id": "chip-remove",
        "description": "Per-chip remove button; opens the remove-confirm modal. data-node=\"chip-remove/<pathKey>\"."
      },
      {
        "id": "rename",
        "description": "Inline rename input for a chip, shown after a double-click. data-node=\"rename/<pathKey>\"."
      },
      {
        "id": "add-btn",
        "description": "Add-folder button; opens the folder-picker modal."
      },
      {
        "id": "add-modal",
        "description": "Add-folder modal backdrop; click closes it."
      },
      {
        "id": "add-tree",
        "description": "Folder-picker tree container inside the add-folder modal."
      },
      {
        "id": "add-err",
        "description": "Error line inside the add-folder modal."
      },
      {
        "id": "add-confirm",
        "description": "Confirm button that registers the picked folder."
      },
      {
        "id": "remove-modal",
        "description": "Remove-confirm modal backdrop; click closes it."
      },
      {
        "id": "remove-cancel",
        "description": "Cancel button in the remove-confirm modal."
      },
      {
        "id": "remove-confirm",
        "description": "Confirm button that unregisters the folder from the list."
      }
    ]
  }
}
